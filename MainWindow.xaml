<Window x:Class="LogCollectorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сбор логов с серверов" Height="550" Width="950"
        WindowStartupLocation="CenterScreen">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Группа серверов -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Группа серверов:" VerticalAlignment="Center" FontSize="14" Width="150"/>
            <ComboBox x:Name="cmbGroup" Width="200" FontSize="14" 
                      SelectionChanged="CmbGroup_SelectionChanged"/>
        </StackPanel>

        <!-- Начальное время -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Начало поиска:" VerticalAlignment="Center" FontSize="14" Width="150"/>
            <TextBox x:Name="txtDateTimeStart" Width="200" FontSize="14" 
                     Text="19.06.2026 15:00" ToolTip="Формат: ДД.ММ.ГГГГ ЧЧ:ММ"/>
        </StackPanel>

        <!-- Конечное время -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Конец поиска:" VerticalAlignment="Center" FontSize="14" Width="150"/>
            <TextBox x:Name="txtDateTimeEnd" Width="200" FontSize="14" 
                     Text="19.06.2026 16:00" ToolTip="Формат: ДД.ММ.ГГГГ ЧЧ:ММ"/>
        </StackPanel>

        <!-- Кнопка запуска -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Top">
            <Button x:Name="btnSearch" Content="Начать сбор логов" Width="200" 
                    FontSize="14" Click="BtnSearch_Click" IsEnabled="False"/>
            <TextBlock x:Name="txtServerCount" VerticalAlignment="Center" Margin="20,0,0,0" 
                       FontSize="12" Foreground="Gray"/>
            <TextBlock x:Name="txtSelectedCount" VerticalAlignment="Center" Margin="20,0,0,0" 
                       FontSize="12" Foreground="Blue"/>
        </StackPanel>

        <!-- Таблица серверов с чекбоксами -->
        <DataGrid x:Name="dgServers" Grid.Row="3" 
                  AutoGenerateColumns="False" IsReadOnly="False"
                  SelectionMode="Extended" CanUserAddRows="False" CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal" AlternatingRowBackground="#F5F5F5"
                  Margin="0,50,0,0">
            <DataGrid.Columns>
                <!-- Чекбокс для выбора сервера -->
                <DataGridCheckBoxColumn Header="Выбрать" Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                <DataGridTextColumn Header="Имя сервера" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="IP-адрес" Binding="{Binding IpAddress}" Width="*"/>
                <DataGridTextColumn Header="Порт SSH" Binding="{Binding SshPort}" Width="100"/>
                <DataGridCheckBoxColumn Header="Активен" Binding="{Binding IsActive}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Строка статуса -->
        <TextBlock x:Name="txtStatus" Grid.Row="4" Text="Выберите группу серверов" 
                   Margin="0,15,0,0" Foreground="Gray" FontSize="12"/>
    </Grid>
</Window>