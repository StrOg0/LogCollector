<Window x:Class="LogCollectorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сбор логов с серверов" Height="500" Width="900"
        WindowStartupLocation="CenterScreen">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель выбора группы и даты/времени -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Группа серверов:" VerticalAlignment="Center" FontSize="14" Width="150"/>
                <ComboBox x:Name="cmbGroup" Width="200" FontSize="14" 
                          SelectionChanged="CmbGroup_SelectionChanged"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Дата и время:" VerticalAlignment="Center" FontSize="14" Width="150"/>
                <TextBox x:Name="txtDateTime" Width="200" FontSize="14" 
                         Text="19.06.2026 15:00" ToolTip="Формат: ДД.ММ.ГГГГ ЧЧ:ММ"/>
            </StackPanel>
        </StackPanel>

        <!-- Кнопка запуска поиска -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <Button x:Name="btnSearch" Content="Начать сбор логов" Width="200" 
                    FontSize="14" Click="BtnSearch_Click" IsEnabled="False"/>
            <TextBlock x:Name="txtServerCount" VerticalAlignment="Center" Margin="20,0,0,0" 
                       FontSize="12" Foreground="Gray"/>
        </StackPanel>

        <!-- Таблица серверов выбранной группы -->
        <DataGrid x:Name="dgServers" Grid.Row="2" 
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" CanUserAddRows="False" CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal" AlternatingRowBackground="#F5F5F5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Имя сервера" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="IP-адрес" Binding="{Binding IpAddress}" Width="*"/>
                <DataGridTextColumn Header="Порт SSH" Binding="{Binding SshPort}" Width="100"/>
                <DataGridCheckBoxColumn Header="Активен" Binding="{Binding IsActive}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Строка статуса -->
        <TextBlock x:Name="txtStatus" Grid.Row="3" Text="Выберите группу серверов" 
                   Margin="0,15,0,0" Foreground="Gray" FontSize="12"/>
    </Grid>
</Window>