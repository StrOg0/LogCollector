<Window x:Class="LogCollectorApp.Windows.GroupEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование группы" Height="560" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Название группы:" Margin="0,0,0,5"/>
                <TextBox x:Name="txtName" Margin="0,0,0,15" Padding="5"/>

                <TextBlock Text="Описание:" Margin="0,0,0,5"/>
                <TextBox x:Name="txtDescription" Margin="0,0,0,15" Padding="5" AcceptsReturn="True" Height="60"/>

                <TextBlock Text="Путь к текущим логам:" Margin="0,0,0,5"/>
                <TextBox x:Name="txtLogPath" Margin="0,0,0,15" Padding="5"
                         ToolTip="Например: /digdes/TK/dock/ddmwebapi_log"/>

                <TextBlock Text="Путь к архивам логов:" Margin="0,0,0,5"/>
                <TextBox x:Name="txtArchivePath" Margin="0,0,0,15" Padding="5"
                         ToolTip="Можно оставить пустым, если у группы нет отдельного архива"/>

                <TextBlock Text="Маска файла:" Margin="0,0,0,5"/>
                <TextBox x:Name="txtFileMask" Margin="0,0,0,15" Padding="5"
                         ToolTip="Например: DDM_Web.log или log {yyyy}Y{MM}M{dd}D"/>

                <TextBlock Text="Маска поиска:" Margin="0,0,0,5"/>
                <TextBox x:Name="txtSearchMask" Margin="0,0,0,15" Padding="5"
                         ToolTip="Например: {yyyy-MM-dd} {HH}:{mm}:"/>

                <TextBlock Text="Кодировка логов:" Margin="0,0,0,5"/>
                <TextBox x:Name="txtEncoding" Margin="0,0,0,15" Padding="5" Text="UTF-8"
                         ToolTip="Например: UTF-8"/>

                <CheckBox x:Name="chkIsActive" Content="Активна" Margin="0,0,0,15" IsChecked="True"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Сохранить" Width="100" Margin="0,0,10,0" Click="BtnSave_Click"/>
            <Button Content="Отмена" Width="100" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
