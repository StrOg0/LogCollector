<Window x:Class="LogCollectorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сбор логов с серверов" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Группа серверов:" VerticalAlignment="Center" FontSize="14" Width="150"/>
            <ComboBox x:Name="cmbGroup" Width="250" FontSize="14" 
                      SelectionChanged="CmbGroup_SelectionChanged"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Начало поиска:" VerticalAlignment="Center" FontSize="14" Width="150"/>
            <TextBox x:Name="txtDateTimeStart" Width="250" FontSize="14" 
                     Text="19.06.2026 15:00" ToolTip="Формат: ДД.ММ.ГГГГ ЧЧ:ММ"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Конец поиска:" VerticalAlignment="Center" FontSize="14" Width="150"/>
            <TextBox x:Name="txtDateTimeEnd" Width="250" FontSize="14" 
                     Text="19.06.2026 16:00" ToolTip="Формат: ДД.ММ.ГГГГ ЧЧ:ММ"/>
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="btnSearch" Content="▶ Начать сбор логов" Width="180" Height="30"
                    FontSize="14" FontWeight="Bold" Click="BtnSearch_Click" IsEnabled="False"
                    Background="#4CAF50" Foreground="White"/>
            
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="10,5"/>
            
            <Button x:Name="btnSettings" Content="⚙ Настройки" Width="120" Margin="0,0,5,0" 
                    Click="BtnSettings_Click"/>
            <Button x:Name="btnOutputPath" Content="📁 Папка вывода" Width="130" Margin="0,0,5,0" 
                    Click="BtnOutputPath_Click"/>
            
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="10,5"/>
            
            <Button x:Name="btnAddGroup" Content="+ Группа" Width="100" Margin="0,0,5,0" 
                    Click="BtnAddGroup_Click"/>
            <Button x:Name="btnEditGroup" Content="✎ Группа" Width="100" Margin="0,0,5,0" 
                    Click="BtnEditGroup_Click"/>
            <Button x:Name="btnAddServer" Content="+ Сервер" Width="100" Margin="0,0,5,0" 
                    Click="BtnAddServer_Click"/>
            <Button x:Name="btnEditServer" Content="✎ Сервер" Width="100" 
                    Click="BtnEditServer_Click"/>
            
            <TextBlock x:Name="txtServerCount" VerticalAlignment="Center" Margin="20,0,0,0" 
                       FontSize="12" Foreground="Gray"/>
            <TextBlock x:Name="txtSelectedCount" VerticalAlignment="Center" Margin="15,0,0,0" 
                       FontSize="12" Foreground="Blue"/>
        </StackPanel>
        <DataGrid x:Name="dgServers" Grid.Row="4" 
                  AutoGenerateColumns="False" IsReadOnly="False"
                  SelectionMode="Extended" CanUserAddRows="False" CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal" AlternatingRowBackground="#F5F5F5"
                  HeadersVisibility="Column"
                  CellEditEnding="DgServers_CellEditEnding">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Выбрать" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox HorizontalAlignment="Center"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Checked="ChkServerSelected_Changed"
                                      Unchecked="ChkServerSelected_Changed"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Имя сервера" Width="*"
                                    Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="IP-адрес" Width="*"
                                    Binding="{Binding IpAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="Порт SSH" Width="100"
                                    Binding="{Binding SshPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <DataGridTemplateColumn Header="Активен" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox HorizontalAlignment="Center"
                                      IsChecked="{Binding IsActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Checked="ChkServerActive_Changed"
                                      Unchecked="ChkServerActive_Changed"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <TextBlock x:Name="txtStatus" Grid.Row="5" Text="Выберите группу серверов" 
                   Margin="0,15,0,0" Foreground="Gray" FontSize="12"/>
    </Grid>
</Window>